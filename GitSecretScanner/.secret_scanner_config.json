{
    "ignore_dirs": [".git", "node_modules", "__pycache__", "venv", "idea"],
    "ignore_files": ["git_scaner.py"],
    "patterns": {
        "API": "([0-9A-Z]+_KEY\\w*)\\s?[:=]\\s?[\\'\\\"]?([0-9a-zA-Z\\s\\._-]+)[\\'\\\"]?",
        "AWS": "(AKIA[0-9a-zA-z]{16})",
        "GIT": "(gh[pousr]_[a-zA-Z0-9]{36})",
        "SSH": "(-----BEGIN.+-----)",
        "GENERIC": "(?:password|passwd|token)\\s?[:=]\\s?[\\'\\\"]?([0-9a-zA-Z\\s\\._-]+)[\\'\\\"]?"
    }
}